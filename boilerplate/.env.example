# App
PORT=3000
DATA_DIR=/app/data

# --- API Keys (Tier 1: set here, never ask user) ---
# Add your app's API keys here
# MY_API_KEY=

# --- Database (uncomment if using db service) ---
# DATABASE_URL=postgres://app:localdev@db:5432/app
# DB_NAME=app
# DB_USER=app
# DB_PASSWORD=localdev

# --- Browser automation (uncomment if using chrome service) ---
# BROWSER_WS_ENDPOINT=ws://chrome:3000
